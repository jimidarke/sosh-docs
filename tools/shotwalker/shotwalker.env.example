# Copy to `shotwalker.env` (gitignored) and fill in.
#
# Nothing here is defaulted in source. sosh-docs is a PUBLIC repo, and the README
# is explicit: no infrastructure or network details, no auth internals. An
# appliance address and console password committed here would be on the public
# internet.

# The Commander's address on your network.
SOSH_HOST=

# Console sign-in (HTTP Basic).
SOSH_USER=
SOSH_PASS=

# Optional — override if the surfaces aren't on the default ports.
# SOSH_CONSOLE_URL=
# SOSH_DESIGNER_URL=
